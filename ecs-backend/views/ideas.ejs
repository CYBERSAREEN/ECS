<%- include('partials/head', { title: 'Ideas & Patents | Excelon Cyber Solutions', description: 'Patents driving the future of cybersecurity — and an open door for your novel ideas.' }) %>
<%- include('partials/loader') %>
<%- include('partials/header', { active: '/ideas' }) %>

<main>
  <header class="page-header">
    <div class="ph-lines"></div>
    <div class="ph-accent"></div>
    <div class="ph-accent-2"></div>
    <div class="container-narrow">
      <span class="eyebrow reveal">INTELLECTUAL PROPERTY</span>
      <h1 class="reveal" data-delay="1">Ideas &amp; Patents</h1>
      <p class="reveal" data-delay="2">Patents driving the future of cybersecurity — and an open door for your novel ideas.</p>
    </div>
  </header>

  <!-- ═══ Our Patents ══════════════════════════════════════════════ -->
  <section class="section section--alt">
    <div class="container-narrow">
      <div class="section-head reveal" style="text-align:left;max-width:none;margin-bottom:36px;">
        <span class="eyebrow">OUR PATENTS</span>
        <h2>Intellectual Property</h2>
        <p>Click a patent to expand full details.</p>
      </div>

      <%
        var pats;
        if (typeof dbPatents !== 'undefined' && dbPatents.length) {
          pats = dbPatents;
        } else {
          pats = [
            { application_number:'202611069735', status:'Approved', title:'PENBOX-DMAS: A Distributed Multi-Agent Security Appliance for Autonomous Vulnerability Assessment and Remediation at the Edge', date:'2026-04-29', ref_no:'UTI4236', patent_code:'UPTRAYAMBAK260519-4236', sdg:'Industry, Innovation, and Infrastructure', pdf_url:'/patents/penbox-dmas.pdf',
              inventors:[{ name:'Vedant Sareen', designation:'Student', dept:'Computer Science & Engineering', email:'vedant1318.be23@chitkara.edu.in' },{ name:'Dr. Himanshi Babbar', designation:'Assistant Professor', dept:'Computer Science & Engineering', email:'himanshi.babbar@chitkara.edu.in' }] },
            { application_number:'202611055845', status:'Filed', title:'Artificial Intelligence Based Learning and Skill Assessment Platform for Cybersecurity', date:'2025-12-01', ref_no:'UTI3812', patent_code:'UPENBL260310-3812', sdg:'Industry, Innovation, and Infrastructure', pdf_url:'/patents/ai-cyber-tutor.pdf',
              inventors:[{ name:'Vedant Sareen', designation:'Student', dept:'Computer Science & Engineering', email:'vedant1318.be23@chitkara.edu.in' },{ name:'Dr. Himanshi Babbar', designation:'Assistant Professor', dept:'CURIN, Chitkara University', email:'himanshi.babbar916@gmail.com' }] }
          ];
        }
        function fmtDate(d){
          if (!d) return '';
          var dt = new Date(d);
          if (isNaN(dt)) return d;
          var m = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
          return String(dt.getUTCDate()).padStart(2,'0') + '-' + m[dt.getUTCMonth()] + '-' + dt.getUTCFullYear();
        }
        pats.forEach(function(p, pi){
          var invs = Array.isArray(p.inventors) ? p.inventors : [];
      %>
      <div class="card patent reveal" data-accordion-item <% if (pi > 0) { %>style="margin-top:18px;"<% } %>>
        <button class="patent__head" data-accordion>
          <span style="flex:1;">
            <span style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:12px;">
              <span class="status-pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg> <%- p.status %></span>
              <span class="kv">App #<%- p.application_number %></span>
            </span>
            <h3 style="font-size:1.05rem;line-height:1.4;"><%- p.title %></h3>
            <p class="kv" style="margin-top:8px;">Date: <%= fmtDate(p.date) %><% if (p.ref_no) { %> &nbsp;·&nbsp; Ref: <%- p.ref_no %><% } %></p>
          </span>
          <svg class="svc__chev" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="patent__body"><div class="patent__body-inner">
          <div class="grid grid-2" style="gap:16px;margin-bottom:20px;">
            <% if (p.patent_code) { %><div><span class="kv">PATENT CODE</span><p style="color:var(--charcoal);font-size:.9rem;margin-top:4px;"><%- p.patent_code %></p></div><% } %>
            <% if (p.sdg) { %><div><span class="kv">SDG ALIGNMENT</span><p style="color:var(--charcoal);font-size:.9rem;margin-top:4px;"><%- p.sdg %></p></div><% } %>
          </div>
          <% if (invs.length) { %>
          <span class="kv">INVENTORS</span>
          <div class="grid grid-2" style="gap:12px;margin-top:8px;">
            <% invs.forEach(function(inv){ %>
            <div class="inv-card">
              <p style="font-weight:700;color:var(--charcoal-2);font-size:.9rem;"><%= inv.name %></p>
              <% if (inv.designation || inv.dept) { %><p style="font-size:.78rem;margin-top:2px;"><%= [inv.designation, inv.dept].filter(Boolean).join(' · ') %></p><% } %>
              <% if (inv.email) { %><p style="font-size:.78rem;margin-top:2px;word-break:break-all;"><%= inv.email %></p><% } %>
            </div>
            <% }); %>
          </div>
          <% } %>
          <% if (p.pdf_url) { %>
          <a href="<%= p.pdf_url %>" download class="btn btn-primary" style="margin-top:20px;padding:10px 18px;font-size:.85rem;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            Download Patent PDF
          </a>
          <% } %>
        </div></div>
      </div>
      <% }); %>
    </div>
  </section>

  <!-- ═══ Open Innovation — Patent Submission ═══════════════════════ -->
  <section class="section">
    <div class="container" style="max-width:1100px;">

      <!-- Section intro -->
      <div class="inno-intro reveal">
        <div>
          <span class="eyebrow">OPEN INNOVATION</span>
          <h2 style="margin:12px 0 16px;">Have a Novel Idea?</h2>
          <p style="font-size:1.1rem;max-width:580px;">If you believe your idea is patent-worthy, we can help you file it for just <strong style="color:var(--red);font-size:1.2em;">₹899/—</strong> — including full refinement and submission support. <strong style="color:var(--charcoal-2);">You remain the first inventor.</strong></p>
        </div>
        <div class="inno-highlights">
          <div class="ih-card">
            <span class="ih-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span>
            <div>
              <strong>1-Year Validity</strong>
              <p>Filing is valid for one full year from the date of submission.</p>
            </div>
          </div>
          <div class="ih-card">
            <span class="ih-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
            <div>
              <strong>2 Co-Authors</strong>
              <p>Your name + a Chitkara University faculty collaborator (Vedant Sareen &amp; Dr. Himanshi Babbar).</p>
            </div>
          </div>
          <div class="ih-card">
            <span class="ih-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
            <div>
              <strong>You Stay #1</strong>
              <p>You are always listed as the primary/first inventor. Full IP ownership rights.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Two-column: market rates + form -->
      <div class="inno-body">

        <!-- LEFT: Market rates -->
        <div class="reveal">
          <p style="font-family:var(--font-mono);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--red);margin-bottom:16px;">Market Reference Rates — What Others Pay</p>
          <div style="overflow-x:auto;">
            <table class="market-table">
              <thead>
                <tr>
                  <th>Entity Type</th>
                  <th>Filing Fee</th>
                  <th>Examination Fee</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Individual / DPIIT-Recognised Startup</td>
                  <td>₹1,600</td>
                  <td>₹4,000</td>
                  <td>₹5,600</td>
                </tr>
                <tr>
                  <td>Small Entity (MSME)</td>
                  <td>₹4,000</td>
                  <td>₹10,000</td>
                  <td>₹14,000</td>
                </tr>
                <tr>
                  <td>Large Entity / Corporate</td>
                  <td>₹8,000</td>
                  <td>₹20,000</td>
                  <td>₹28,000</td>
                </tr>
                <tr class="ecs-row">
                  <td><strong>With Excelon CS</strong></td>
                  <td colspan="2"><strong>All-inclusive, end-to-end</strong></td>
                  <td><strong>₹899/—</strong></td>
                </tr>
              </tbody>
            </table>
          </div>
          <p style="font-size:0.76rem;color:var(--muted-2);margin-top:10px;">Market reference rates — source: <a href="https://ipindia.gov.in" target="_blank" rel="noopener" style="color:var(--red);">ipindia.gov.in</a> &amp; google.com</p>

          <!-- Process steps -->
          <div style="margin-top:32px;">
            <p style="font-family:var(--font-mono);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--red);margin-bottom:16px;">How It Works</p>
            <div class="process-steps">
              <div class="ps-item">
                <span class="ps-n">01</span>
                <div><strong>Submit your idea</strong><p>Fill the form with your patent title and a brief description or PDF.</p></div>
              </div>
              <div class="ps-item">
                <span class="ps-n">02</span>
                <div><strong>We review &amp; refine</strong><p>Our team reviews your idea within 48 hours and contacts you to refine the claim language.</p></div>
              </div>
              <div class="ps-item">
                <span class="ps-n">03</span>
                <div><strong>Filing &amp; tracking</strong><p>We file with the Indian Patent Office and keep you updated through approval.</p></div>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Submission form -->
        <div class="reveal" data-delay="1">
          <p style="font-family:var(--font-mono);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--red);margin-bottom:20px;">Submit Your Patent Idea</p>

          <form id="patentForm" novalidate>
            <div class="field"><label>Your Name <span style="color:var(--red);">*</span></label><input class="input" name="submitter_name" required placeholder="Full name" /></div>
            <div class="field"><label>Organization / Designation</label><input class="input" name="organization" placeholder="Student / Engineer / Founder..." /></div>
            <div class="field"><label>Patent Title <span style="color:var(--red);">*</span></label><input class="input" name="patent_title" required placeholder="e.g. AI-Based Intrusion Detection System" /></div>
            <div class="field">
              <label>Patent Idea Document</label>
              <p style="font-size:0.8rem;color:var(--muted-2);margin-bottom:8px;">PDF only, max 4 MB. Optional — you can describe your idea in the title instead.</p>
              <input class="input" type="file" name="file" accept="application/pdf,.pdf" style="padding:9px 14px;" />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:8px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-7 20-4-9-9-4z"/><path d="M22 2 11 13"/></svg>
              Submit Patent Idea
            </button>
            <p id="patentErr" style="text-align:center;color:#f87171;font-size:.85rem;margin-top:14px;display:none;"></p>
          </form>

          <div id="patentDone" style="display:none;padding:32px 24px;background:var(--red-soft);border:1px solid var(--red-mid);border-radius:var(--radius-lg);text-align:center;margin-top:8px;">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="1.5" style="margin:0 auto 12px;display:block;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>
            <h3 style="margin-bottom:8px;">Idea Received!</h3>
            <p>We&apos;ll review within 48 hours and reach out to discuss next steps.</p>
          </div>
        </div>

      </div>
    </div>
  </section>
</main>

<script>
  document.getElementById('patentForm').addEventListener('submit', async function(e){
    e.preventDefault();
    var f = e.target;
    var errEl = document.getElementById('patentErr');
    errEl.style.display = 'none';

    var fileInput = f.querySelector('input[type="file"]');
    var file = fileInput.files[0];
    if (file) {
      if (!/\.pdf$/i.test(file.name) || (file.type && file.type !== 'application/pdf')) {
        errEl.textContent = 'Only PDF files are accepted.'; errEl.style.display = 'block'; return;
      }
      if (file.size > 4 * 1024 * 1024) {
        errEl.textContent = 'PDF too large — maximum 4 MB.'; errEl.style.display = 'block'; return;
      }
    }
    if (!f.submitter_name.value.trim() || !f.patent_title.value.trim()) {
      errEl.textContent = 'Name and patent title are required.'; errEl.style.display = 'block'; return;
    }

    var fd = new FormData();
    fd.append('submitter_name', f.submitter_name.value.trim());
    fd.append('organization', f.organization.value.trim());
    fd.append('patent_title', f.patent_title.value.trim());
    if (file) fd.append('file', file);

    try {
      var res = await fetch('/api/patents/submit', { method:'POST', body: fd });
      if (!res.ok) {
        var j = await res.json().catch(function(){ return {}; });
        errEl.textContent = j.error || (j.errors && j.errors[0] && j.errors[0].msg) || 'Submission failed — try again.';
        errEl.style.display = 'block';
        return;
      }
    } catch(err){
      errEl.textContent = 'Network error — try again.'; errEl.style.display = 'block'; return;
    }
    f.style.display = 'none';
    document.getElementById('patentDone').style.display = 'block';
  });
</script>

<style>
/* ── Open Innovation section ──────── */
.inno-intro {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: start;
  margin-bottom: 56px;
  padding-bottom: 48px;
  border-bottom: 1px solid var(--border);
}

.inno-highlights { display: flex; flex-direction: column; gap: 16px; }
.ih-card {
  display: flex;
  gap: 14px;
  padding: 16px 18px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color 0.2s;
}
.ih-card:hover { border-color: var(--red-mid); }
.ih-icon {
  width: 40px; height: 40px;
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: var(--red-soft);
  border: 1px solid var(--red-mid);
  border-radius: 8px;
  color: var(--red);
}
.ih-icon svg { width: 20px; height: 20px; }
.ih-card strong { display: block; font-size: 0.95rem; color: var(--charcoal-2); margin-bottom: 3px; }
.ih-card p { font-size: 0.83rem; color: var(--muted); margin: 0; line-height: 1.6; }

.inno-body {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 60px;
  align-items: start;
}

/* Process steps */
.process-steps { display: flex; flex-direction: column; gap: 0; }
.ps-item {
  display: flex;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
}
.ps-item:last-child { border-bottom: none; }
.ps-n {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--red);
  letter-spacing: 0.06em;
  flex-shrink: 0;
  padding-top: 3px;
  min-width: 24px;
}
.ps-item strong { display: block; font-size: 0.9rem; color: var(--charcoal-2); margin-bottom: 3px; }
.ps-item p { font-size: 0.82rem; color: var(--muted); margin: 0; line-height: 1.6; }

/* Responsive */
@media (max-width: 900px) {
  .inno-intro { grid-template-columns: 1fr; gap: 32px; }
  .inno-body { grid-template-columns: 1fr; gap: 40px; }
}
</style>

<%- include('partials/footer') %>
