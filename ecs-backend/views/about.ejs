<%- include('partials/head', { title: 'About | Excelon Cyber Solutions', description: 'Meet Vandana Kochhar — Founder, Director & CTO of Excelon Cyber Solutions. Visionary leader in AI-powered cybersecurity.' }) %>
<%- include('partials/loader') %>
<%- include('partials/header', { active: '/about' }) %>

<main>
  <header class="page-header">
    <div class="ph-lines"></div>
    <div class="ph-accent"></div>
    <div class="ph-accent-2"></div>
    <div class="container-narrow">
      <span class="eyebrow reveal">ABOUT</span>
      <h1 class="reveal" data-delay="1">Vandana Kochhar</h1>
      <p class="reveal" data-delay="2">Founder &amp; Director · CTO — the visionary building a safer digital future for everyone.</p>
    </div>
  </header>

  <!-- ═══ Founder Spotlight ═══════════════════════════════════════ -->
  <section class="section section--alt" style="padding:80px 0;">
    <div class="container" style="max-width:1100px;">
      <div class="founder-layout">

        <!-- LEFT: Photo -->
        <div class="founder-photo-col reveal">
          <div class="founder-frame">
            <div class="founder-frame__glow"></div>
            <div class="founder-frame__border">
              <img src="/img/team/vandana.jpeg" alt="Vandana Kochhar — Founder, Director & CTO" class="founder-img" />
              <div class="founder-overlay"></div>
            </div>
            <div class="founder-name-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--red)" stroke="none"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
              FOUNDER · DIRECTOR &amp; CTO
            </div>
          </div>
          <div class="founder-stats-row">
            <div class="fs-item">
              <span class="fs-num">14+</span>
              <span class="fs-label">Years Vision</span>
            </div>
            <div class="fs-sep"></div>
            <div class="fs-item">
              <span class="fs-num">2</span>
              <span class="fs-label">Patents</span>
            </div>
            <div class="fs-sep"></div>
            <div class="fs-item">
              <span class="fs-num">0</span>
              <span class="fs-label">False Positives</span>
            </div>
          </div>
        </div>

        <!-- RIGHT: Bio -->
        <div class="founder-bio-col reveal" data-delay="1">
          <span class="eyebrow">EXCELON CYBER SOLUTIONS</span>
          <h2 style="margin:12px 0 20px;font-size:clamp(1.6rem,3vw,2.4rem);">The vision behind<br/>the mission.</h2>

          <p style="font-size:1.1rem;color:var(--charcoal);line-height:1.75;margin-bottom:24px;">Mrs. Vandana Kochhar is the Founder and Director of Excelon Cyber Solutions Pvt. Ltd., leading the company's vision, growth strategy, and commitment to creating a safer digital future. With a strong focus on innovation and accessibility, she champions initiatives that bridge the gap between advanced cybersecurity and everyday users.</p>

          <!-- Focus panels -->
          <div class="founder-focus-grid">
            <div class="ff-card">
              <div class="ff-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <strong>AI-Powered Security</strong>
                <p>Overseeing development of AI-driven security solutions, WAPT platforms, and adaptive tools that protect individuals, businesses, and communities.</p>
              </div>
            </div>
            <div class="ff-card">
              <div class="ff-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <strong>Community Empowerment</strong>
                <p>Guiding children's cyber education, digital literacy initiatives, and scam-awareness platforms for senior citizens — making safety universal.</p>
              </div>
            </div>
            <div class="ff-card">
              <div class="ff-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div>
                <strong>Web 4.0 Vision</strong>
                <p>Actively building toward a future where every citizen has a personalised, AI-powered protection system — regardless of age or background.</p>
              </div>
            </div>
            <div class="ff-card">
              <div class="ff-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              </div>
              <div>
                <strong>Zero Compromise</strong>
                <p>Under her leadership, cybersecurity is not just a technical service but a fundamental right — your digital identity is as real as your physical one.</p>
              </div>
            </div>
          </div>

          <!-- Expertise pills -->
          <div class="expertise-pills">
            <span class="ep">AI Security</span>
            <span class="ep">Cyber Education</span>
            <span class="ep">WAPT</span>
            <span class="ep">Digital Literacy</span>
            <span class="ep">Strategic Vision</span>
            <span class="ep">Startup Growth</span>
          </div>

          <!-- Quote -->
          <div class="founder-quote">
            <svg class="fq-mark" viewBox="0 0 40 32" fill="currentColor"><path d="M0 32V19.2C0 14.4 1.6 10.24 4.8 6.72 8 3.2 12.267 1.067 17.6 0l2.4 4.16c-3.2.747-5.76 2.027-7.68 3.84C10.4 9.813 9.387 12.32 9.28 15.52H16V32H0zm24 0V19.2c0-4.8 1.6-8.96 4.8-12.48C32 3.2 36.267 1.067 41.6 0L44 4.16c-3.2.747-5.76 2.027-7.68 3.84-1.92 1.813-2.933 4.32-3.04 7.52H40V32H24z"/></svg>
            <p>Security is the main goal.</p>
            <span class="fq-attr">— Vandana Kochhar, Founder &amp; CTO</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Expertise Domains ════════════════════════════════════════ -->
  <section class="section" style="padding:80px 0;">
    <div class="container" style="max-width:1100px;">
      <div class="section-head reveal" style="margin-bottom:48px;">
        <span class="eyebrow">WHAT WE DO BEST</span>
        <h2>Expertise Domains</h2>
        <p>Four pillars that define every engagement we take on.</p>
      </div>
      <div class="grid grid-4">
        <div class="card reveal">
          <span class="card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
          <h3>Penetration Testing</h3>
          <p>AI-assisted WAPT with zero false negatives. Every engagement is scoped, documented, and backed by reproducible proof-of-concept.</p>
        </div>
        <div class="card reveal" data-delay="1">
          <span class="card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07M8.46 8.46a5 5 0 0 0 0 7.07"/></svg></span>
          <h3>AI Automation</h3>
          <p>Patent-pending distributed multi-agent frameworks for autonomous vulnerability assessment, triage, and remediation at scale.</p>
        </div>
        <div class="card reveal" data-delay="2">
          <span class="card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></span>
          <h3>Cyber Education</h3>
          <p>AI-powered personalised learning paths for aspiring security engineers and digital safety awareness for everyday citizens.</p>
        </div>
        <div class="card reveal" data-delay="3">
          <span class="card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></span>
          <h3>Secure Web Dev</h3>
          <p>Secure-by-design full-stack applications — from architecture to deployment — built with OWASP principles as the foundation, not an afterthought.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Team ══════════════════════════════════════════════════════ -->
  <section class="section section--alt" style="padding:80px 0;">
    <div class="container" style="max-width:1100px;">
      <div class="section-head reveal" style="margin-bottom:48px;">
        <span class="eyebrow">THE TEAM</span>
        <h2>People Behind the Mission</h2>
        <p>A dedicated squad of specialists — each an expert in their domain, united under a single vision.</p>
      </div>
      <div class="grid grid-4">
        <%
          var teamTagsMap2 = {
            'Vandana Kochhar': ['AI Strategy','Leadership','Innovation','Education'],
            'Vedant Sareen':   ['WAPT','Red Team','AI Automation','Bug Bounty'],
            'Suneha Passi':    ['Full-Stack','UI/UX','Team Lead','DevOps'],
            'Hardik Garg':     ['EDR/XDR','SOC','SIEM','Purple Team']
          };
          var team;
          if (typeof dbTeam !== 'undefined' && dbTeam.length) {
            team = dbTeam.map(function(m){
              var ini = m.initials || (m.name || '').split(/\s+/).map(function(w){ return w[0]; }).join('').slice(0,2).toUpperCase();
              return { name: m.name, role: m.role, photo: m.photo_url || '', initials: ini, bio: m.bio || '', featured: m.sort_order === 1, tags: teamTagsMap2[m.name] || [] };
            });
          } else {
            team = [
              { name:'Vandana Kochhar', role:'Founder · Director & CTO', photo:'/img/team/vandana.jpeg', initials:'VK', bio:'Founder and Director of Excelon CS. Driving the AI-powered security vision — from enterprise WAPT to digital safety programs for children and senior citizens.', featured:true, tags:['AI Strategy','Leadership','Innovation','Education'] },
              { name:'Vedant Sareen', role:'Senior Security Analyst', photo:'/img/team/vedant.jpeg', initials:'VS', bio:'Ex-EY Senior Security Analyst, VAPT specialist, and Red Teamer. Patent holder for PenBox DMAS. Active bug bounty researcher across global programs.', tags:['WAPT','Red Team','AI Automation','Bug Bounty'] },
              { name:'Suneha Passi', role:'Senior Web Developer · Team Lead', photo:'/img/team/suneha.jpeg', initials:'SP', bio:'Senior full-stack developer and team lead. Delivers secure, responsive web products in React and Node.js — from architecture to production deployment.', tags:['Full-Stack','UI/UX','Team Lead','DevOps'] },
              { name:'Hardik Garg', role:'EDR & SOC Specialist · Purple Teamer', photo:'/img/team/hardik.jpeg', initials:'HG', bio:'Certified Purple Teamer with deep SOC and SIEM expertise. Leads EDR/XDR telemetry, threat hunting, and automated red teaming for enterprise defence.', tags:['EDR/XDR','SOC','SIEM','Purple Team'] }
            ];
          }
          team.forEach(function(m, i){ %>
          <div class="card team-card <%= m.featured ? 'featured' : '' %> reveal" data-delay="<%= i % 4 %>">
            <div class="team-avatar">
              <% if (m.photo) { %><img src="<%= m.photo %>" alt="<%- m.name %>" /><% } else { %><div class="initials"><%= m.initials %></div><% } %>
            </div>
            <h3><%- m.name %></h3>
            <div class="role"><%- m.role %></div>
            <p><%- m.bio || '' %></p>
            <% if(m.tags && m.tags.length){ %>
            <div class="team-tags"><% m.tags.forEach(function(t){ %><span class="team-tag"><%- t %></span><% }); %></div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- ═══ Mission & Vision ═════════════════════════════════════════ -->
  <section class="section" style="padding:80px 0;">
    <div class="container" style="max-width:1060px;">
      <div class="section-head reveal" style="margin-bottom:48px;">
        <span class="eyebrow">PURPOSE</span>
        <h2>Mission &amp; Vision</h2>
      </div>
      <div class="grid grid-2">
        <div class="card reveal" style="padding:40px;">
          <span class="card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1"/></svg></span>
          <h3>Our Mission</h3>
          <p>To earn your trust and secure your digital identity as if it were our own. Privacy is non-negotiable — the moment you share your data with the digital world, you are trusting someone to protect it. We take that responsibility personally.</p>
          <div style="margin-top:20px;padding:14px 18px;background:var(--red-soft);border-left:3px solid var(--red);border-radius:0 var(--radius) var(--radius) 0;">
            <p style="color:var(--charcoal-2);font-style:italic;font-size:1rem;margin:0;">Your digital identity is as real — and as vulnerable — as your physical one.</p>
          </div>
        </div>
        <div class="card reveal" data-delay="1" style="padding:40px;">
          <span class="card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg></span>
          <h3>Our Vision</h3>
          <p>By the time Web 4.0 arrives, we want every aspiring security engineer and every ordinary citizen to have a personalised, AI-powered learning path and protection system that meets them exactly where they are.</p>
          <div style="margin-top:20px;padding:14px 18px;background:var(--red-soft);border-left:3px solid var(--red);border-radius:0 var(--radius) var(--radius) 0;">
            <p style="color:var(--charcoal-2);font-style:italic;font-size:1rem;margin:0;">Regardless of age, background, or technical expertise.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Timeline ═════════════════════════════════════════════════ -->
  <section class="section section--alt" style="padding:80px 0;">
    <div class="container-narrow">
      <div class="section-head reveal" style="margin-bottom:48px;">
        <span class="eyebrow">COMPANY JOURNEY</span>
        <h2>Our Story</h2>
      </div>
      <div class="timeline">
        <%
          var tl = [
            { yr:'2012', e:'Excelon Cyber Solutions founded in Ludhiana, Punjab, India' },
            { yr:'2023', e:'First enterprise WAPT engagement — zero false positives, zero false negatives' },
            { yr:'2024', e:'PenBox DMAS patent filed — distributed AI security appliance (Approved 2026)' },
            { yr:'2025', e:'AI Cyber Tutor patent application submitted — adaptive AI for cybersecurity education' },
            { yr:'2026', e:'Expanding into startup consultancy, children\'s cyber education, and Web 4.0 security research' }
          ];
          tl.forEach(function(t){ %>
          <div class="tl-item reveal">
            <div class="yr"><%= t.yr %></div>
            <p><%= t.e %></p>
          </div>
        <% }); %>
      </div>
    </div>
  </section>
</main>

<style>
/* ── Founder Layout ─────────────────────────── */
.founder-layout {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 64px;
  align-items: start;
}

/* Photo frame */
.founder-photo-col { display: flex; flex-direction: column; align-items: center; gap: 20px; }

.founder-frame {
  position: relative;
  width: 100%;
  max-width: 340px;
}
.founder-frame__glow {
  position: absolute;
  inset: -30px;
  background: radial-gradient(ellipse at center, rgba(233,79,55,0.28) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
  border-radius: 50%;
}
.founder-frame__border {
  position: relative;
  z-index: 1;
  padding: 3px;
  background: linear-gradient(145deg, var(--red) 0%, rgba(233,79,55,0.25) 45%, var(--red-dark) 100%);
  border-radius: calc(var(--radius-lg) + 3px);
  box-shadow: 0 12px 60px rgba(233,79,55,0.22), 0 4px 20px rgba(0,0,0,0.5);
}
.founder-img {
  display: block;
  width: 100%;
  aspect-ratio: 4/5;
  object-fit: cover;
  object-position: top center;
  border-radius: var(--radius-lg);
}
.founder-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 45%;
  background: linear-gradient(to top, rgba(233,79,55,0.18) 0%, transparent 100%);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  pointer-events: none;
}
.founder-name-badge {
  position: absolute;
  bottom: -14px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  background: var(--red);
  color: #fff;
  padding: 7px 18px;
  border-radius: 999px;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 7px;
  box-shadow: 0 4px 20px rgba(233,79,55,0.45);
}

/* Stats row */
.founder-stats-row {
  display: flex;
  align-items: center;
  gap: 0;
  background: var(--cream);
  border: 1px solid var(--border-mid);
  border-radius: var(--radius);
  overflow: hidden;
  width: 100%;
  max-width: 340px;
  margin-top: 8px;
}
.fs-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14px 8px;
  gap: 3px;
}
.fs-num {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1.8rem;
  color: var(--red);
  line-height: 1;
  text-shadow: 0 0 20px rgba(233,79,55,0.35);
}
.fs-label {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: var(--muted);
  text-align: center;
}
.fs-sep {
  width: 1px;
  height: 40px;
  background: var(--border-mid);
  flex-shrink: 0;
}

/* Bio column */
.founder-bio-col {}

/* Focus grid */
.founder-focus-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin: 0 0 24px;
}
.ff-card {
  display: flex;
  gap: 12px;
  padding: 16px;
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color 0.2s, background 0.2s;
}
.ff-card:hover { border-color: var(--red-mid); background: var(--red-soft); }
.ff-icon {
  width: 36px;
  height: 36px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--red-soft);
  border: 1px solid var(--red-mid);
  border-radius: 8px;
  color: var(--red);
}
.ff-icon svg { width: 18px; height: 18px; }
.ff-card strong { display: block; font-size: 0.88rem; font-weight: 700; color: var(--charcoal-2); margin-bottom: 4px; }
.ff-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.6; margin: 0; }

/* Expertise pills */
.expertise-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}
.ep {
  padding: 5px 14px;
  background: var(--red-soft);
  border: 1px solid var(--red-mid);
  border-radius: 999px;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--red);
}

/* Quote */
.founder-quote {
  position: relative;
  padding: 24px 28px 24px 48px;
  background: var(--cream);
  border: 1px solid var(--border-mid);
  border-left: 3px solid var(--red);
  border-radius: 0 var(--radius) var(--radius) 0;
}
.fq-mark {
  position: absolute;
  top: 16px;
  left: 14px;
  width: 22px;
  height: 18px;
  color: var(--red);
  opacity: 0.5;
}
.founder-quote p {
  font-size: 1.25rem;
  font-style: italic;
  color: var(--charcoal-2);
  line-height: 1.5;
  margin: 0 0 8px;
}
.fq-attr {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--red);
}

/* ── Responsive ─────────────────────────────── */
@media (max-width: 900px) {
  .founder-layout {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .founder-photo-col { align-items: center; }
  .founder-frame { max-width: 280px; }
  .founder-stats-row { max-width: 280px; }
}
@media (max-width: 600px) {
  .founder-focus-grid { grid-template-columns: 1fr; }
}
</style>

<%- include('partials/footer') %>
