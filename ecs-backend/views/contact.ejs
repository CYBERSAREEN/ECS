<%- include('partials/head', { title: 'Contact | Excelon Cyber Solutions', description: 'Get in touch — your enquiry reaches us instantly via WhatsApp. We respond within 2 hours.' }) %>
<%- include('partials/loader') %>
<%- include('partials/header', { active: '/contact' }) %>

<main>
  <header class="page-header">
    <div class="ph-lines"></div>
    <div class="ph-accent"></div>
    <div class="container-narrow">
      <span class="eyebrow reveal">GET IN TOUCH</span>
      <h1 class="reveal" data-delay="1">Let&apos;s Talk Security</h1>
      <p class="reveal" data-delay="2">Fill the form and your enquiry reaches us instantly via WhatsApp. We typically respond within 2 hours.</p>
    </div>
  </header>

  <section class="section section--alt">
    <div class="container" style="max-width:1000px;">
      <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:40px;align-items:start;" class="contact-grid">

        <!-- Info -->
        <div class="reveal">
          <div class="info-card">
            <span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="m4 6 8 6 8-6"/></svg></span>
            <div><div class="il">EMAIL</div><a class="iv" href="mailto:securecybernetics@gmail.com">securecybernetics@gmail.com</a></div>
          </div>
          <div class="info-card">
            <span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span>
            <div><div class="il">WHATSAPP</div><a class="iv" href="https://wa.me/917087603933" target="_blank" rel="noopener">+91 70876 03933</a></div>
          </div>
          <div class="info-card">
            <span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
            <div><div class="il">PHONE</div><a class="iv" href="tel:+917087603933">+91 70876 03933</a></div>
          </div>
          <div class="info-card">
            <span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
            <div><div class="il">LOCATION</div><div class="iv">Ludhiana, Punjab, India</div></div>
          </div>
          <div style="margin-top:24px;padding:20px 24px;background:var(--cream);border:1px solid var(--border-mid);border-radius:var(--radius-lg);">
            <a href="https://wa.me/917087603933?text=Hi%2C%20I%27d%20like%20to%20get%20a%20quote%20for%20a%20security%20assessment." target="_blank" rel="noopener" class="btn btn-primary" style="width:100%;justify-content:center;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.8-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.7 1-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.6-.4zM12 2a10 10 0 0 0-8.6 15l-1.4 5 5.1-1.3A10 10 0 1 0 12 2z"/></svg>
              WhatsApp Us Directly
            </a>
          </div>
        </div>

        <!-- Form -->
        <div class="reveal" data-delay="1">
          <form id="contactForm" class="form-card" novalidate>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
              <div class="field"><label>Your Name *</label><input class="input" name="name" required /></div>
              <div class="field"><label>Email ID *</label><input class="input" type="email" name="email" required /></div>
            </div>
            <div class="field"><label>WhatsApp Number *</label><input class="input" type="tel" name="phone" placeholder="+91 98765 43210" required pattern="[+0-9][0-9 \-]{7,16}" /></div>
            <div class="field"><label>Organization</label><input class="input" name="organization" /></div>
            <div class="field"><label>Service Required *</label>
              <select class="select" name="service" required>
                <option value="">Select a service...</option>
                <option>Web Development</option>
                <option>Web Application Penetration Testing (WAPT)</option>
                <option>AI-Based Cyber Tutor</option>
                <option>Startup Consultancy</option>
                <option>Security Consulting</option>
                <option>Bug Bounty Assistance</option>
                <option>Other</option>
              </select>
            </div>
            <div class="field"><label>Message</label><textarea class="textarea" name="message"></textarea></div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-7 20-4-9-9-4z"/><path d="M22 2 11 13"/></svg>
              Verify &amp; Send via WhatsApp
            </button>
          </form>
          <div id="contactDone" class="form-card text-center" style="display:none;">
            <span class="card__icon" style="margin:0 auto 12px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg></span>
            <h3>Message Sent!</h3>
            <p style="margin-top:6px;">WhatsApp opened with your enquiry. We&apos;ll respond shortly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  document.getElementById('contactForm').addEventListener('submit', async function(e){
    e.preventDefault();
    var f = e.target;
    if (!f.checkValidity()) { f.reportValidity(); return; }
    var data = { name:f.name.value, email:f.email.value, phone:f.phone.value, organization:f.organization.value, service_required:f.service.value, message:f.message.value };
    try { await fetch('/api/contact', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data) }); } catch(err){}
    var txt = encodeURIComponent('Hi this is ' + f.name.value + ', I have gone through the website and acknowledge all related services but I want to enquire about ' + f.service.value + ', please guide me for the same!!');
    window.open('https://wa.me/917087603933?text=' + txt, '_blank');
    f.style.display = 'none';
    document.getElementById('contactDone').style.display = 'block';
  });
</script>

<style>@media(max-width:768px){.contact-grid{grid-template-columns:1fr !important;}.form-card div[style*="grid-template-columns:1fr 1fr"]{grid-template-columns:1fr !important;}}</style>

<%- include('partials/footer') %>
