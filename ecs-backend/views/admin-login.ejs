<%- include('partials/head', { title: 'Admin Access | ECS', description: 'Restricted area.' }) %>

<div class="admin-login">
  <div class="grid-bg"></div>
  <div class="ambient-glow" style="inset:0;"></div>
  <div class="admin-login__card">
    <div class="text-center" style="margin-bottom:28px;">
      <img src="/brand/ecs-shield-cream.svg" alt="ECS" style="height:56px;margin:0 auto;" />
    </div>
    <div class="admin-login__box">
      <div class="admin-login__head">
        <span class="ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
        <div><h3>Admin Access</h3><p>Restricted · Authorized only</p></div>
      </div>
      <form id="loginForm" autocomplete="off" novalidate>
        <div class="field"><label>Username</label><input class="input" name="username" autocomplete="off" required /></div>
        <div class="field"><label>Password</label><input class="input" type="password" name="password" autocomplete="off" required /></div>
        <p id="loginErr" class="admin-login__err"></p>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">Access Dashboard</button>
      </form>
    </div>
    <p class="admin-login__foot">EXCELON CYBER SOLUTIONS © <%= new Date().getFullYear() %></p>
  </div>
</div>

<script>
  document.getElementById('loginForm').addEventListener('submit', async function(e){
    e.preventDefault();
    var f = e.target;
    var err = document.getElementById('loginErr');
    err.style.display = 'none';
    try {
      var res = await fetch('/api/admin/login', { method:'POST', headers:{'Content-Type':'application/json'}, credentials:'include', body: JSON.stringify({ username:f.username.value.trim(), password:f.password.value.trim() }) });
      if (res.ok) { window.location.href = '/vadmin-db7180/dashboard'; }
      else if (res.status === 429) { err.textContent = 'Too many attempts — locked for 15 minutes. Wait and try again.'; err.style.display = 'block'; }
      else { err.textContent = 'Invalid credentials. Please try again.'; err.style.display = 'block'; }
    } catch(e2) { err.textContent = 'Authentication service unavailable.'; err.style.display = 'block'; }
  });
</script>
</body>
</html>
