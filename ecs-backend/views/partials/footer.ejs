<!-- Theme switcher -->
<div class="theme-fab" id="themeFab">
  <div class="theme-panel" id="themePanel" aria-label="Colour themes">
    <p class="theme-panel__title">Choose a palette</p>
    <%
      var themes = [
        { id: 'editorial', label: 'Editorial', dots: ['#f6f7eb', '#e94f37', '#393e41'] },
        { id: 'ocean',     label: 'Ocean',     dots: ['#f3f6fa', '#2563eb', '#16202c'] },
        { id: 'forest',    label: 'Forest',    dots: ['#f4f6ef', '#3f6f44', '#1f261f'] },
        { id: 'sand',      label: 'Sand',      dots: ['#faf6ee', '#b07020', '#2a241a'] },
        { id: 'mono',      label: 'Mono',      dots: ['#f5f5f4', '#18181b', '#3f3f46'] },
        { id: 'plum',      label: 'Plum',      dots: ['#f7f4f8', '#6b21a8', '#221d27'] }
      ];
      themes.forEach(function(t){ %>
    <button class="theme-opt" data-theme-pick="<%= t.id %>">
      <span class="theme-opt__dots">
        <% t.dots.forEach(function(d){ %><span style="background:<%= d %>;"></span><% }); %>
      </span>
      <%= t.label %>
      <svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
    </button>
    <% }); %>
  </div>
  <button class="theme-fab__btn" id="themeToggle" aria-label="Change colour theme" aria-expanded="false">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M12 2a10 10 0 0 0 0 20c1.1 0 2-.9 2-2 0-.5-.2-1-.5-1.3-.3-.4-.5-.8-.5-1.3 0-1.1.9-2 2-2h2.4A4.6 4.6 0 0 0 22 10.8 9.4 9.4 0 0 0 12 2z"/>
      <circle cx="7.5" cy="11.5" r="1.2" fill="currentColor" stroke="none"/>
      <circle cx="11" cy="7.5" r="1.2" fill="currentColor" stroke="none"/>
      <circle cx="16" cy="8.5" r="1.2" fill="currentColor" stroke="none"/>
    </svg>
  </button>
</div>

<script src="/js/main.js?v=<%= assetV %>"></script>
</body>
