PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin auth (bcrypt hash of password — run: npm run setup:hash)
ADMIN_USERNAME=V3d@n5login
ADMIN_PASSWORD_HASH=$2a$12$REPLACE_WITH_REAL_BCRYPT_HASH

# JWT
JWT_SECRET=replace_with_long_random_secret_min_64_chars

# Email (Resend)
RESEND_API_KEY=re_your_key_here
RESEND_FROM=ECS <noreply@excelong.in>
ADMIN_EMAIL=securecybernetics@gmail.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# SEO / canonical base URL (production domain)
SITE_URL=http://localhost:3000

# Google Analytics 4 — leave empty to disable tracking entirely
GA_MEASUREMENT_ID=

# QuickScan scanner — all core checks are keyless/free. Optional free-tier keys:
# urlscan.io (free account → API key) — page snapshot + tech fingerprint
URLSCAN_API_KEY=
# Google Safe Browsing (free tier, Google Cloud console) — malware/phishing check
SAFE_BROWSING_API_KEY=
